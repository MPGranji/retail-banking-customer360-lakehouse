# Oracle source
ORACLE_USER=core_banking
ORACLE_PASSWORD=CHANGE_ME
ORACLE_HOST=oracle
ORACLE_PORT=1521
ORACLE_SERVICE=XEPDB1

# PostgreSQL source, Airflow metadata, ETL flags and Iceberg catalog
POSTGRES_USER=card_crm
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=card_crm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
AIRFLOW_DB=airflow

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_BUCKET=lakehouse

# Iceberg REST catalog
ICEBERG_REST_HOST=iceberg-rest
ICEBERG_REST_PORT=8181
ICEBERG_CATALOG_URI=http://iceberg-rest:8181
ICEBERG_WAREHOUSE=s3://lakehouse/warehouse
ICEBERG_DB=iceberg_catalog

# Spark
SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEBUI_PORT=9090
SPARK_WORKER_MEMORY=1g
SPARK_WORKER_CORES=1

# Trino
TRINO_HOST=trino
TRINO_PORT=8443
# Generate unique values locally. Never commit docker/.env or runtime keystores.
TRINO_KEYSTORE_PASSWORD=CHANGE_ME
TRINO_SHARED_SECRET=CHANGE_ME
TRINO_MARKETING_PASSWORD=CHANGE_ME
TRINO_ENGINEERING_PASSWORD=CHANGE_ME

# Airflow
# Generate a Fernet key instead of committing one:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=CHANGE_ME
AIRFLOW_SECRET_KEY=CHANGE_ME
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME
AIRFLOW_ADMIN_EMAIL=admin@example.com

# PII masking
PII_HASH_SALT=CHANGE_ME
