{
    "display_name": "PySpark (Lakehouse)",
    "language": "python",
    "argv": [
        "python3",
        "-m", "ipykernel_launcher",
        "-f", "{connection_file}"
    ],
    "env": {
        "INIT_PYSPARK": "true",
        "PYSPARK_PYTHON": "python3",
        "PYSPARK_DRIVER_PYTHON": "python3"
    }
}
